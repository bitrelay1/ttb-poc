# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ttb_labels

# Anthropic API key — used for label OCR and field verification
ANTHROPIC_API_KEY=sk-ant-...

# Session signing key and audit log HMAC — minimum 32 characters, random hex
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-64-char-hex-string

# ── Authentication (at least one block below must be configured) ───────────────

# Option A: Google OAuth — recommended for production
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Option B: Demo bypass — required if Google OAuth is not configured
# Use a random suffix; known-weak values (e.g. "ttb-demo", "demo", "test") are rejected at startup
DEMO_BYPASS_CODE=ttb-demo-<random-suffix>
# If set, entering this code grants admin role; omit to disable admin via demo bypass
DEMO_ADMIN_CODE=ttb-admin-<random-suffix>

# ── Optional ──────────────────────────────────────────────────────────────────

# Email address auto-promoted to admin on first startup — bootstraps admin access
INITIAL_ADMIN_EMAIL=

# Set to "production" to harden API visibility (hides /docs and /redoc)
ENV=

# Set to true when a TLS-terminating proxy sits in front of the app (e.g. Railway)
SECURE_COOKIES=false

# ── Docker Compose only (not read by FastAPI — used by the postgres service) ──

POSTGRES_DB=ttb_labels
POSTGRES_USER=ttb_app
POSTGRES_PASSWORD=change-this-password
